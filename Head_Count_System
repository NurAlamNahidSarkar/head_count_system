ea:.0f} px²\")\nprint()\n\n# Check 5 frames\nfor frame_num in [0, 30, 60, 90, 120]:\n    cap.set(cv2.CAP_PROP_POS_FRAMES, frame_num)\n    ret, frame = cap.read()\n    if not ret:\n        continue\n\n    results = model(\n        frame,\n        conf=0.3,\n        iou=0.45,\n        classes=[0],\n        device=DEVICE,\n        verbose=False,\n    )[0]\n\n    detections = sv.Detections.from_ultralytics(results)\n    print(f\"--- Frame {frame_num} ---\")\n    print(f\"  Total detections : {len(detections)}\")\n\n    if len(detections) == 0:\n        print(\"  ⚠ No people detected at all in this frame\")\n        continue\n\n    # Check each detection centroid\n    inside_count = 0\n    for i, xyxy in enumerate(detections.xyxy):\n        cx = int((xyxy[0] + xyxy[2]) / 2)\n        cy = int((xyxy[1] + xyxy[3]) / 2)\n        inside = zone_polygon.contains(Point(cx, cy))\n        if inside:\n            inside_count += 1\n        if i < 5:  # print first 5 detections\n            print(f\"  det[{i}] centroid=({cx},{cy})  inside={inside}  box={[int(v) for v in xyxy]}\")\n\n    print(f\"  Detections inside polygon : {inside_count} / {len(detections)}\")\n    print()\n\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nprint(\"=== VIDEO SIZE ===\")\nprint(f\"Video : {width}x{height}\")\nprint(f\"Polygon points were drawn on first_frame size : {first_frame.shape[1]}x{first_frame.shape[0]}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-10T07:46:03.029624Z","iopub.execute_input":"2026-05-10T07:46:03.030311Z","iopub.status.idle":"2026-05-10T07:46:04.427084Z","shell.execute_reply.started":"2026-05-10T07:46:03.030274Z","shell.execute_reply":"2026-05-10T07:46:04.426366Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Focused debug — fixed version\n\nfrom shapely.geometry import Point\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import Polygon as MplPoly\n\n# ── Reopen the video fresh — do not r