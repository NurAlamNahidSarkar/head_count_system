notated, f\"Total unique: {len(counted_ids)}\",\n                (20, 68), cv2.FONT_HERSHEY_SIMPLEX, 0.9, (0, 200, 255), 2)\n\n    out.write(annotated)\n\n    if frame_idx % log_every == 0:\n        secs = frame_idx / fps\n        print(f\"  t={secs:6.1f}s | frame {frame_idx:5d} \"\n              f\"| in zone: {len(inside_ids):4d} \"\n              f\"| total unique: {len(counted_ids):4d}\")\n\n    frame_idx += 1\n\ncap.release()\nout.release()\n\nprint(f\"\\n✅ Done — {frame_idx} frames processed\")\nprint(f\"   People ever entered polygon (unique): {len(counted_ids)}\")\nprint(f\"   Output saved → {OUTPUT_PATH}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-10T07:46:26.595781Z","iopub.execute_input":"2026-05-10T07:46:26.596558Z","iopub.status.idle":"2026-05-10T07:49:18.790352Z","shell.execute_reply.started":"2026-05-10T07:46:26.596520Z","shell.execute_reply":"2026-05-10T07:49:18.789422Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"!zip -r output_files.zip /kaggle/working/output_counted.mp4","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"from IPython.display import FileLink\nFileLink(r'output_files.zip')","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}