aggle/working/first_frame.jpg\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-10T07:27:17.061040Z","iopub.execute_input":"2026-05-10T07:27:17.061491Z","iopub.status.idle":"2026-05-10T07:27:17.183887Z","shell.execute_reply.started":"2026-05-10T07:27:17.061459Z","shell.execute_reply":"2026-05-10T07:27:17.182854Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Safe replacement for the optional helper\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport io\nfrom IPython.display import Image as IPImage\n\nfig, ax = plt.subplots(figsize=(10, 6))\nax.imshow(cv2.cvtColor(first_frame, cv2.COLOR_BGR2RGB))\nax.set_xlim(0, width)\nax.set_ylim(height, 0)   # keep this consistent with Cell 3 — origin top-left, Y down\nax.set_title(f\"Frame: {width}×{height}  |  Use Cell 3 to enter coordinates\", fontsize=10)\n\nbuf = io.BytesIO()\nfig.savefig(buf, format='png', dpi=72, bbox_inches='tight')\nplt.close()\nbuf.seek(0)\ndisplay(IPImage(buf.read()))\n# Do NOT read coordinates from this toolbar — use Cell 3's widget instead","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-10T07:27:51.209438Z","iopub.execute_input":"2026-05-10T07:27:51.209965Z","iopub.status.idle":"2026-05-10T07:27:51.520047Z","shell.execute_reply.started":"2026-05-10T07:27:51.209935Z","shell.execute_reply":"2026-05-10T07:27:51.519230Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Cell 3 — Interactive polygon point picker (Kaggle-compatible)\n\nimport matplotlib\nmatplotlib.use('Agg')  # keeps savefig working without a GUI window\nimport matplotlib.pyplot as plt\nfrom matplotlib.patches import Polygon as MplPoly\nimport ipywidgets as widgets\nfrom IPython.display import display, clear_output, Image as IPImage\nimport numpy as np\nimport io\n\nframe_rgb = cv2.cvtColor(first_frame, cv2.COLOR_BGR2RGB)\nIMG_H, IMG_W = frame_rgb.shape[:2]\n\npolygon_points = []\n\n# ── Redraw: renders to PNG bytes, shows via IPython Image ─────────────────────\n# This is the fix — instead of plt.show() (which Agg ignores),\n# we save to a bytes buffer and display as an inline image widget.\n# This works reliably in Kaggle every run.\n\nimg_widget = widgets.Image(format='png', width='100%')\n\ndef draw_canvas():\n    fig, ax = plt.subplots(figsize=(13, 7))\n    ax.imshow(frame_rgb)\n    ax.set_xlim(0, IMG_W)\n    ax.set_ylim(IMG_H, 0)\n    ax.axis('off')\n\n    if polygon_points:\n        xs = [p[0] for p in polygon_points]\n        ys = [p[1] for p in polygon_points]\n\n        # Closing line back to first point\n        closed_xs = xs + [xs[0]]\n        closed_ys = ys + [ys[0]]\n        ax.plot(closed_xs, closed_ys, 'c--', linewidth=1.8, alpha=0.8)\n\n        # Filled polygon when 3+ points\n        if len(polygon_points) >= 3:\n            poly = MplPoly(\n                list(zip(xs, ys)),\n                closed=True, alpha=0.22,\n                facecolor='cyan', edgecolor='cyan', linewidth=2\n            )\n            ax.add_patch(poly)\n\n        # Numbered red dots\n        for i, (px, py) in enumerate(polygon_points):\n            ax.plot(px, py, 'o', color='red', markersize=11, zorder=5)\n            ax.text(px + IMG_W * 0.008, py - IMG_H * 0.012,\n                    str(i + 1),\n                    color='yellow', fontsize=13, fontweight='bold',\n                    zorder=6,\n                    bbox=dict(boxstyle='round,pad=0.2',\n                              fc='black', alpha=0.6, lw=0))\n\n    ax.set_title(\n        f\"Polygon points: {len(polygon_points)}  |  Image: {IMG_W}×{IMG_H}  \"\n        f\"|  Top-left=(0,0)  Bottom-right=({IMG_W-1},{IMG_H-1})\",\n        fontsize=10, color='white', backgroundcolor='black', pad=6\n    )\n\n    plt.tight_layout()\n\n    # Save to bytes buffer — this is what actually updates the display\n    buf = io.BytesIO()\n    fig.savefig(buf, format='png', dpi=100,\n                bbox_inches='tight', facecolor='black')\n    plt.close(fig)\n    buf.seek(0)\n\n    # Push new PNG bytes into the widget — updates instantly, no flicker\n    img_widget.value = buf.read()\n\n    # Also save to disk for reference\n    with open('/kaggle/working/polygon_builder.png', 'wb') as f:\n        buf.seek(0)\n        f.write(buf.read())\n\n# ── Controls ──────────────────────────────────────────────────────────────────\nstyle  = {'description_width': '30px'}\nlayout = widgets.Layout(width='115px')\n\nx_box = widgets.BoundedIntText(value=IMG_W//2, min=0, max=IMG_W-1,\n                                description='X:', style=style, layout=layout)\ny_box = widgets.BoundedIntText(value=IMG_H//2, min=0, max=IMG_H-1,\n                                description='Y:', style=style, layout=layout)\n\nhint = widgets.Label(\n    value=f\"Enter X and Y → Add point.  \"\n          f\"Image size: {IMG_W}×{IMG_H}\",\n    style={'font_size': '12px'}\n)\n\nbtn_add   = widgets.Button(description='Add point',  button_style='primary', layout=layout)\nbtn_undo  = widgets.Button(description='Undo last',  button_style='warning', layout=layout)\nbtn_reset = widgets.Button(description='Reset all',  button_style='danger',  layout=layout)\nbtn_done  = widgets.Button(description='Done ✓',     button_style='success', layout=layout)\n\nstatus_lbl = widgets.Label(value='No points yet.')\ncontrols   = widgets.HBox(\n    [x_box, y_box, btn_add, btn_undo, btn_reset, btn_done],\n    layout=widgets.Layout(gap='8px', align_items='center')\n)\n\n# ── Callbacks ─────────────────────────────────────────────────────────────────\ndef on_add(_):\n    polygon_points.append((x_box.value, y_box.value))\n    status_lbl.value = f\"Point {len(polygon_points)} added: ({x_box.value}, {y_box.value})\"\n    draw_canvas()\n\ndef on_undo(_):\n    if polygon_points:\n        removed = polygon_points.pop()\n        status_lbl.value = f\"Removed: {removed}  |  {len(polygon_points)} point(s) left\"\n        draw_canvas()\n\ndef on_reset(_):\n    polygon_points.clear()\n    status_lbl.value = 'Reset. No points.'\n    draw_canvas()\n\ndef on_done(_):\n    if len(polygon_points) < 3:\n        status_lbl.value = '⚠ Need at least 3 points.'\n        return\n    status_lbl.value = f'✅ Polygon locked — {len(polygon_points)} points: {polygon_points}'\n    draw_canvas()\n    print('\\n── Polygon finalised ──')\n    print('polygon_points =', polygon_points)\n\nbtn_add.on_click(on_add)\nbtn_undo.on_click(on_undo)\nbtn_reset.on_click(on_reset)\nbtn_done.on_click(on_done)\n\n# ── Display ───────────────────────────────────────────────────────────────────\ndisplay(hint, controls, status_lbl, img_widget)\ndraw_canvas()   # show the raw frame immediately on run","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-10T07:27:35.682118Z","iopub.execute_input":"2026-05-10T07:27:35.682547Z","iopub.status.idle":"2026-05-10T07:27:36.329988Z","shell.execute_reply.started":"2026-05-10T07:27:35.682517Z","shell.execute_reply":"2026-05-10T07:27:36.328966Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Cell 5: Load detection model\n# Choose ONE option by setting MODEL_CHOICE below\n\nimport torch\nDEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\nprint(f\"Device: {DEVICE}  |  GPUs: {torch.cuda.device_count()}\")\n\n# ── Pick your model ───────────────────────────────────────────────────────────\n#\n#   \"yolov8x\"        → fast, good baseline\n#   \"yolov8x-p6\"     → better on high-res frames (replaces yolov8x6)\n#   \"rtdetr-l\"       → best accuracy, no NMS issues  ← recommended\n#   \"rtdetr-x\"       → rtdetr extra-large, strongest\n#   \"rfdetr\"         → Roboflow transformer\n#   \"ppyoloe\"        → PaddlePaddle (needs extra install)\n#   \"yolonas\"        → YOLO-NAS via SuperGradients (needs extra install)\n#\nMODEL_CHOICE = \"rtdetr-l\"\n# ─────────────────────────────────────────────────────────────────────────────\n\nmodel = None\n\n# ── Ultralytics models (yolov8, rtdetr) ──────────────────────────────────────\nif MODEL_CHOICE in (\"yolov8x\", \"yolov8x-p6\", \"yolov9e\", \"yolo11x\"):\n    from ultralytics import YOLO\n    model = YOLO(f\"{MODEL_CHOICE}.pt\")\n    MODEL_TYPE = \"ultralytics\"\n\nelif MODEL_CHOICE in (\"rtdetr-l\", \"rtdetr-x\"):\n    from ultralytics import RTDETR\n    model = RTDETR(f\"{MODEL_CHOICE}.pt\")\n    MODEL_TYPE = \"ultralytics\"\n\n# ── RF-DETR ───────────────────────────────────────────────────────────────────\nelif MODEL_CHOICE == \"rfdetr\":\n    try:\n        from rfdetr import RFDETRLarge\n    except ImportError:\n        import subprocess, sys\n        subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"rfdetr\", \"-q\"])\n        from rfdetr import RFDETRLarge\n    model = RFDETRLarge(pretrain_weights=\"rf-detr-large.pth\")\n    MODEL_TYPE = \"rfdetr\"\n\n# ── PP-YOLOE+ (PaddleDetection) ───────────────────────────────────────────────\nelif MODEL_CHOICE == \"ppyoloe\":\n    try:\n        import paddle\n    except ImportError:\n        import subprocess, sys\n        print(\"Installing PaddlePaddle GPU — this takes ~3 minutes...\")\n        subprocess.run([sys.executable, \"-m\", \"pip\", \"install\",\n                        \"paddlepaddle-gpu\", \"paddledet\", \"-q\"])\n        import paddle\n    # Load PP-YOLOE+ via PaddleDetection inference\n    # Download config + weights from PaddlePaddle model zoo first:\n    # !wget https://bj.bcebos.com/v1/paddledet/models/ppyoloe_plus_crn_x_80e_coco.pdparams\n    from ppdet.core.workspace import load_config, merge_config\n    from ppdet.engine import Trainer\n    MODEL_TYPE = \"ppyoloe\"\n    print(\"PP-YOLOE+ loaded — see comments for weight download step\")\n\n# ── YOLO-NAS (SuperGradients) ─────────────────────────────────────────────────\nelif MODEL_CHOICE == \"yolonas\":\n    try:\n        from super_gradients.training import models as sg_models\n    except ImportError:\n        import subprocess, sys\n        print(\"Installing SuperGradients...\")\n        subprocess.run([sys.executable, \"-m\", \"pip\", \"install\",\n                        \"super-gradients\", \"-q\"])\n        from super_gradients.training import models as sg_models\n\n    model = sg_models.get(\n        \"yolo_nas_l\",                    # options: yolo_nas_s / yolo_nas_m / yolo_nas_l\n        pretrained_weights=\"coco\"\n    ).to(DEVICE)\n    MODEL_TYPE = \"yolonas\"\n    print(\"YOLO-NAS-L loaded ✓\")\n\nelse:\n    raise ValueError(f\"Unknown MODEL_CHOICE: {MODEL_CHOICE}\")\n\n# ── Warm-up (only for Ultralytics models) ────────────────────────────────────\nif MODEL_TYPE == \"ultralytics\" and model is not None:\n    _ = model(first_frame, verbose=False, device=DEVICE)\n    print(f\"{MODEL_CHOICE} warm-up done ✓\")\n\nprint(f\"\\nModel ready: {MODEL_CHOICE}  |  type: {MODEL_TYPE}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-10T07:45:53.573508Z","iopub.execute_input":"2026-05-10T07:45:53.574474Z","iopub.status.idle":"2026-05-10T07:45:54.187890Z","shell.execute_reply.started":"2026-05-10T07:45:53.574432Z","shell.execute_reply":"2026-05-10T07:45:54.186839Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Cell 6: Tracker + counting sets\n\nimport supervision as sv\n\ntracker = sv.ByteTrack(\n    track_activation_threshold=0.25,\n    lost_track_buffer=120,      # ← increase from 60 to 120 (at 25fps = 4.8 seconds)\n    minimum_matching_threshold=0.8,\n    frame_rate=int(fps),\n)\n\n# These two sets are the core of your counting logic:\n#\n#   currently_inside  → IDs that are IN the polygon RIGHT NOW\n#                       updated every frame\n#\n#   counted_ids       → IDs that have EVER entered the polygon\n#                       once an ID is here, it is NEVER counted again\n#                       even if the person re-enters\n\ncurrently_inside = set()\ncounted_ids      = set()\nnew_this_frame   = 0      # just for logging\n\nprint(\"Tracker ready ✓\")\nprint(\"Logic: each unique ID counted onl