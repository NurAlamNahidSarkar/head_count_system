rt matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport io\nfrom IPython.display import Image as IPImage\n\nfig, ax = plt.subplots(figsize=(10, 6))\nax.imshow(cv2.cvtColor(first_frame, cv2.COLOR_BGR2RGB))\nax.set_xlim(0, width)\nax.set_ylim(height, 0)   # keep this consistent with Cell 3 — origin top-left, Y down\nax.set_title(f\"Frame: {width}×{height}  |  Use Cell 3 to enter coordinates\", fontsize=10)\n\nbuf = io.BytesIO()\nfig.savefig(buf, format='png', dpi=72, bbox_inches='tight')\nplt.close()\nbuf.seek(0)\ndisplay(IPImage(buf.read()))\n# Do NOT read coordinates from this toolbar — use Cell 3's widget instead","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-11T04:14:55.161952Z","iopub.execute_input":"2026-05-11T04:14:55.162926Z","iopub.status.idle":"2026-05-11T04:14:55.594690Z","shell.execute_reply.started":"2026-05-11T04:14:55.162895Z","shell.execute_reply":"2026-05-11T04:14:55.593778Z"}},"outputs":[{"output_type":"display_data","data":{"image/png":"\n","text/plain":"<IPython.core.display.Image object>"},"metadata":{}}],"execution_count":3},{"cell_type":"code","source":"# Cell 3 — Interactive polygon point picker (Kaggle-compatible)\n\nimport matplotlib\nmatplotlib.use('Agg')  # keeps savefig working without a GUI window\nimport matplotlib.pyplot as plt\nfrom matplotlib.patches import Polygon as MplPoly\nimport ipywidgets as widgets\nfrom IPython.display import display, clear_output, Image as IPImage\nimport numpy as np\nimport io\n\nframe_rgb = cv2.cvtColor(first_frame, cv2.COLOR_BGR2RGB)\nIMG_H, IMG_W = frame_rgb.shape[:2]\n\npolygon_points = []\n\n# ── Redraw: renders to PNG bytes, shows via IPython Image ─────────────────────\n# This is the fix — instead of plt.show() (which Agg ignores),\n# we save to a bytes buffer and display as an inline image widget.\n# This works reliably in Kaggle every run.\n\nimg_widget = widgets.Image(format='png', width='100%')\n\ndef draw_canvas():\n    fig, ax = plt.subplots(figsize=(13, 7))\n    ax.imshow(frame_rgb)\n    ax.set_xlim(0, IMG_W)\n    ax.set_ylim(IMG_H, 0)\n    ax.axis('off')\n\n    if polygon_points:\n        xs = [p[0] for p in polygon_points]\n        ys = [p[1] for p in polygon_points]\n\n        # Closing line back to first point\n        closed_xs = xs + [xs[0]]\n        closed_ys = ys + [ys[0]]\n        ax.plot(closed_xs, closed_ys, 'c--', linewidth=1.8, alpha=0.8)\n\n        # Filled polygon when 3+ points\n        if len(polygon_points) >= 3:\n            poly = MplPoly(\n                list(zip(xs, ys)),\n                closed=True, alpha=0.22,\n                facecolor='cyan', edgecolor='cyan', linewidth=2\n            )\n            ax.add_patch(poly)\n\n        # Numbered red dots\n        for i, (px, py) in enumerate(polygon_points):\n            ax.plot(px, py, 'o', color='red', markersize=11, zorder=5)\n            ax.text(px + IMG_W * 0.008, py - IMG_H * 0.012,\n                    str(i + 1),\n                    color='yellow', fontsize=13, fontweight='bold',\n                    zorder=6,\n                    bbox=dict(boxstyle='round,pad=0.2',\n                              fc='black', alpha=0.6, lw=0))\n\n    ax.set_title(\n        f\"Polygon points: {len(polygon_points)}  |  Image: {IMG_W}×{IMG_H}  \"\n        f\"|  Top-left=(0,0)  Bottom-right=({IMG_W-1},{IMG_H-1})\",\n        fontsize=10, color='white', backgroundcolor='black', pad=6\n    )\n\n    plt.tight_layout()\n\n    # Save to bytes buffer — this is what actually updates the display\n    buf = io.BytesIO()\n    fig.savefig(buf, format='png', dpi=100,\n                bbox_inches='tight', facecolor='black')\n    plt.close(fig)\n    buf.seek(0)\n\n    # Push new PNG bytes into the widget — updates instantly, no flicker\n    img_widget.value = buf.read()\n\n    # Also save to disk for reference\n    with open('/kaggle/working/polygon_builder.png', 'wb') as f:\n        buf.seek(0)\n        f.write(buf.read())\n\n# ── Controls ──────────────────────────────────────────────────────────────────\nstyle  = {'description_width': '30px'}\nlayout = widgets.Layout(width='115px')\n\nx_box = widgets.BoundedIntText(value=IMG_W//2, min=0, max=IMG_W-1,\n                                description='X:', style=style, layout=layout)\ny_box = widgets.BoundedIntText(value=IMG_H//2, min=0, max=IMG_H-1,\n                                description='Y:', style=style, layout=layout)\n\nhint = widgets.Label(\n    value=f\"Enter X and Y → Add point.  \"\n          f\"Image size: {IMG_W}×{IMG_H}\",\n    style={'font_size': '12px'}\n)\n\nbtn_add   = widgets.Button(description='Add point',  button_style='primary', layout=layout)\nbtn_undo  = widgets.Button(description='Undo last',  button_style='warning', layout=layout)\nbtn_reset = widgets.Button(description='Reset all',  button_style='danger',  layout=layout)\nbtn_done  = widgets.Button(description='Done ✓',     button_style='success', layout=layout)\n\nstatus_lbl = widgets.Label(value='No points yet.')\ncontrols   = widgets.HBox(\n    [x_box, y_box, btn_add, btn_undo, btn_reset, btn_done],\n    layout=widgets.Layout(gap='8px', align_items='center')\n)\n\n# ── Callbacks ─────────────────────────────────────────────────────────────────\ndef on_add(_):\n    polygon_points.append((x_box.value, y_box.value))\n    status_lbl.value = f\"Point {len(polygon_points)} added: ({x_box.value}, {y_box.value})\"\n    draw_canvas()\n\ndef on_undo(_):\n    if polygon_points:\n        removed = polygon_points.pop()\n        status_lbl.value = f\"Removed: {removed}  |  {len(polygon_points)} point(s) left\"\n        draw_canvas()\n\ndef on_reset(_):\n    polygon_points.clear()\n    status_lbl.value = 'Reset. No points.'\n    draw_canvas()\n\ndef on_done(_):\n    if len(polygon_points) < 3:\n        status_lbl.value = '⚠ Need at least 3 points.'\n        return\n    status_lbl.value = f'✅ Polygon locked — {len(polygon_points)} points: {polygon_points}'\n    draw_canvas()\n    print('\\n── Polygon finalised ──')\n    print('polygon_points =', polygon_points)\n\nbtn_add.on_click(on_add)\nbtn_undo.on_click(on_undo)\nbtn_reset.on_click(on_reset)\nbtn_done.on_click(on_done)\n\n# ── Display ───────────────────────────────────────────────────────────────────\ndisplay(hint, controls, status_lbl, img_widget)\ndraw_canvas()   # show the raw frame immediately on run","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-11T04:14:59.089582Z","iopub.execute_input":"2026-05-11T04:14:59.090455Z","iopub.status.idle":"2026-05-11T04:14:59.764915Z","shell.execute_reply.started":"2026-05-11T04:14:59.090414Z","shell.execute_reply":"2026-05-11T04:14:59.763972Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Label(value='Enter X and Y → Add point.  Image size: 1920×1080', style=LabelStyle(font_size='12px'))","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"b8e06aa969f94ce18585241155f4d995"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"HBox(children=(BoundedIntText(value=960, description='X:', layout=Layout(width='115px'), max=1919, style=Descr…","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"8080b2120933467a9bbaf46acbec1fc4"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Label(value='No points yet.')","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"8dd4fcbd415d4e04b877a1cddfa2d7e4"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Image(value=b'', width='100%')","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"0c054a933890497faa73951cd3f70927"}},"metadata":{}}],"execution_count":4},{"cell_type":"code","source":"# Cell 4 — Interactive line picker for IN/OUT counting (Kaggle-compatible)\n\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport ipywidgets as widgets\nfrom IPython.display import display\nimport numpy as np\nimport io\n\nframe_rgb_line = cv2.cvtColor(first_frame, cv2.COLOR_BGR2RGB)\nIMG_H_L, IMG_W_L = frame_rgb_line.shape[:2]\n\n# Exactly 2 points define the line\nline_points = []\n\nline_img_widget = widgets.Image(format='png', width='100%')\n\ndef draw_line_canvas():\n    fig, ax = plt.subplots(figsize=(13, 7))\n    ax.imshow(frame_rgb_line)\n    ax.set_xlim(0, IMG_W_L)\n    ax.set_ylim(IMG_H_L, 0)\n    ax.axis('off')\n\n    if len(line_points) >= 1:\n        ax.plot(line_points[0][0], line_points[0][1], 'o',\n                color='lime', markersize=13, zorder=5)\n        ax.text(line_points[0][0] + IMG_W_L * 0.008,\n                line_points[0][1] - IMG_H_L * 0.012,\n                'P1', color='yellow', fontsize=13, fontweight='bold', zorder=6,\n                bbox=dict(boxstyle='round,pad=0.2', fc='black', alpha=0.6, lw=0))\n\n    if len(line_points) == 2:\n        ax.plot(line_points[1][0], line_points[1][1], 'o',\n                color='lime', markersize=13, zorder=5)\n        ax.text(line_points[1][0] + IMG_W_L * 0.008,\n                line_points[1][1] - IMG_H_L * 0.012,\n                'P2', color='yellow', fontsize=13, fontweight='bold', zorder=6,\n                bbox=dict(boxstyle='round,pad=0.2', fc='black', alpha=0.6, lw=0))\n\n        # Draw the line\n        ax.plot([line_points[0][0], line_points[1][0]],\n                [line_points[0][1], line_points[1][1]],\n                color='lime', linewidth=2.5, zorder=4)\n\n        # Show direction labels: LEFT side = OUT arrow, RIGHT side = IN arrow\n        mx = (line_points[0][0] + line_points[1][0]) / 2\n        my = (line_points[0][1] + line_points[1][1]) / 2\n        # Perpendicular vector to show IN/OUT sides\n        dx = line_points[1][0] - line_points[0][0]\n        dy = line_points[1][1] - line_points[0][1]\n        length = max((dx**2 + dy**2)**0.5, 1)\n        nx, ny = -dy / length, dx / length  # normal vector\n\n        offset = IMG_W_L * 0.07\n        ax.annotate('→ OUT', xy=(mx + nx * offset, my + ny * offset),\n                    color='red', fontsize=14, fontweight='bold',\n                    ha='center', va='center',\n                    bbox=dict(fc='black', alpha=0.6, lw=0, pad=3))\n        ax.annotate('← IN', xy=(mx - nx * offset, my - ny * offset),\n                    color='cyan', fontsize=14, fontweight='bold',\n                    ha='center', va='center',\n                    bbox=dict(fc='black', alpha=0.6, lw=0, pad=3))\n\n    ax.set_title(\n        f\"Line points: {len(line_points)}/2  |  \"\n        f\"Left→Right cross = OUT  |  Right→Left cross = IN  |  \"\n        f\"Image: {IMG_W_L}×{IMG_H_L}\",\n        fontsize=10, color='white', backgroundcolor='black', pad=6\n    )\n\n    plt.tight_layout()\n    buf = io.BytesIO()\n    fig.savefig(buf, format='png', dpi=100, bbox_inches='tight', facecolor='black')\n    plt.close(fig)\n    buf.seek(0)\n    line_img_widget.value = buf.read()\n\n    with open('/kaggle/working/line_builder.png', 'wb') as f:\n        buf.seek(0)\n        f.write(buf.read())\n\n# ── Controls ──────────────────────────────────────────────────────────────────\nstyle_l  = {'description_width': '30px'}\nlayout_l = widgets.Layout(width='115px')\n\nlx_box = widgets.BoundedIntText(value=IMG_W_L//2, min=0, max=IMG_W_L-1,\n                                 description='X:', style=style_l, layout=layout_l)\nly_box = widgets.BoundedIntText(value=IMG_H_L//2, min=0, max=IMG_H_L-1,\n                                 description='Y:', style=style_l, layout=layout_l)\n\nhint_l = widgets.Label(\n    value=f\"Enter X and Y for P1 then P2 (exactly 2 points).  Image: {IMG_W_L}×{IMG_H_L}\",\n    style={'font_size': '12px'}\n)\n\nbtn_ladd  = widgets.Button(description='Add point', button_style='primary', layout=layout_l)\nbtn_lundo = widgets.Button(description='Undo last',  button_style='warning', layout=layout_l)\nbtn_lreset= widgets.Button(description='Reset',      button_style='danger',  layout=layout_l)\nbtn_